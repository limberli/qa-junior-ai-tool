# Default App Branding
# App name displayed in the app bar when no agent is selected
NEXT_PUBLIC_DEFAULT_APP_NAME="A2A Net"

# App icon path displayed in the app bar when no agent is selected
# Can be a local path (e.g., /logo.png) or a URL
NEXT_PUBLIC_DEFAULT_APP_ICON=/logo.png

# Default Agent Card URLs
# URL to Agent Cards list as JSON to load on startup
# Example: NEXT_PUBLIC_DEFAULT_AGENT_CARDS_URL=http://localhost:4000/agent-cards.json
NEXT_PUBLIC_DEFAULT_AGENT_CARDS_URL=

# Default Custom Headers
# JSON object of HTTP headers to send with every agent request
# Example: NEXT_PUBLIC_DEFAULT_HEADERS={"Authorization":"Bearer token","X-API-Key":"your-key"}
NEXT_PUBLIC_DEFAULT_HEADERS=
